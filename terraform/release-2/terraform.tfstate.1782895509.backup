            "creation_date": "2026-06-12T17:51:15Z",
            "definition": "{\"Comment\":\"Actify Document Generation Pipeline — SDD v1.1\",\"StartAt\":\"AssembleContext\",\"States\":{\"AssembleContext\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"MarkFailed\",\"ResultPath\":\"$.error\"}],\"Next\":\"GenerateSlots\",\"Parameters\":{\"FunctionName\":\"arn:aws:lambda:eu-central-1:265020547280:function:actify-saas-doc-assemble-context\",\"Payload.$\":\"$\"},\"Resource\":\"arn:aws:states:::lambda:invoke\",\"ResultPath\":\"$.context\",\"ResultSelector\":{\"allowedRefs.$\":\"$.Payload.allowedRefs\",\"articleTexts.$\":\"$.Payload.articleTexts\",\"company.$\":\"$.Payload.company\",\"contextS3Key.$\":\"$.Payload.contextS3Key\",\"fixedSections.$\":\"$.Payload.fixedSections\",\"gap.$\":\"$.Payload.gap\",\"generativeSlots.$\":\"$.Payload.generativeSlots\",\"kbVersion.$\":\"$.Payload.kbVersion\",\"modelId.$\":\"$.Payload.modelId\",\"promptVersion.$\":\"$.Payload.promptVersion\",\"schema.$\":\"$.Payload.schema\",\"system.$\":\"$.Payload.system\"},\"Type\":\"Task\"},\"AssembleDocument\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"MarkFailed\",\"ResultPath\":\"$.error\"}],\"Next\":\"RenderPdf\",\"Parameters\":{\"FunctionName\":\"arn:aws:lambda:eu-central-1:265020547280:function:actify-saas-doc-assemble-document\",\"Payload\":{\"companyId.$\":\"$.companyId\",\"context.$\":\"$.context\",\"docType.$\":\"$.docType\",\"generationId.$\":\"$.generationId\",\"slots.$\":\"$.slots\",\"systemId.$\":\"$.systemId\"}},\"Resource\":\"arn:aws:states:::lambda:invoke\",\"ResultPath\":\"$.assembled\",\"ResultSelector\":{\"markdownContent.$\":\"$.Payload.markdownContent\",\"markdownS3Key.$\":\"$.Payload.markdownS3Key\",\"title.$\":\"$.Payload.title\"},\"Type\":\"Task\"},\"CheckValidation1\":{\"Choices\":[{\"BooleanEquals\":true,\"Next\":\"AssembleDocument\",\"Variable\":\"$.validation.passed\"}],\"Default\":\"RetryWithFeedback\",\"Type\":\"Choice\"},\"CheckValidation2\":{\"Choices\":[{\"BooleanEquals\":true,\"Next\":\"AssembleDocument\",\"Variable\":\"$.validation.passed\"}],\"Default\":\"MarkReviewRequired\",\"Type\":\"Choice\"},\"Done\":{\"Type\":\"Succeed\"},\"Fail\":{\"Cause\":\"Pipeline failed — check doc_generations record for details\",\"Error\":\"DocumentGenerationFailed\",\"Type\":\"Fail\"},\"GenerateSlots\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"MarkFailed\",\"ResultPath\":\"$.error\"}],\"ItemSelector\":{\"context.$\":\"$.context\",\"generationId.$\":\"$.generationId\",\"slot.$\":\"$$.Map.Item.Value\"},\"ItemsPath\":\"$.context.generativeSlots\",\"Iterator\":{\"StartAt\":\"GenerateOneSlot\",\"States\":{\"GenerateOneSlot\":{\"End\":true,\"Parameters\":{\"FunctionName\":\"arn:aws:lambda:eu-central-1:265020547280:function:actify-saas-doc-generate-slot\",\"Payload.$\":\"$\"},\"Resource\":\"arn:aws:states:::lambda:invoke\",\"ResultSelector\":{\"content.$\":\"$.Payload.content\",\"slotId.$\":\"$.Payload.slotId\"},\"Type\":\"Task\"}}},\"MaxConcurrency\":3,\"Next\":\"ValidationGate1\",\"ResultPath\":\"$.slots\",\"Type\":\"Map\"},\"MarkFailed\":{\"Next\":\"Fail\",\"Parameters\":{\"FunctionName\":\"arn:aws:lambda:eu-central-1:265020547280:function:actify-saas-doc-persist-audit\",\"Payload\":{\"action\":\"update_status\",\"companyId.$\":\"$.companyId\",\"error.$\":\"$.error\",\"generationId.$\":\"$.generationId\",\"status\":\"FAILED\"}},\"Resource\":\"arn:aws:states:::lambda:invoke\",\"ResultPath\":null,\"Retry\":[{\"ErrorEquals\":[\"States.ALL\"],\"IntervalSeconds\":2,\"MaxAttempts\":1}],\"Type\":\"Task\"},\"MarkReviewRequired\":{\"Next\":\"ReviewRequiredDone\",\"Parameters\":{\"FunctionName\":\"arn:aws:lambda:eu-central-1:265020547280:function:actify-saas-doc-persist-audit\",\"Payload\":{\"action\":\"review_required\",\"companyId.$\":\"$.companyId\",\"context.$\":\"$.context\",\"docType.$\":\"$.docType\",\"gapId.$\":\"$.gapId\",\"generationId.$\":\"$.generationId\",\"slots.$\":\"$.slots\",\"systemId.$\":\"$.systemId\",\"validation.$\":\"$.validation\"}},\"Resource\":